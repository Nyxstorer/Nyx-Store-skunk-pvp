----- AIMBOT + FOV -----
local aimbotEnabled = false
local showFOV = false          -- Começa desligado
local fovRadius = 15
local smoothness = 0.65
local headOffset = Vector3.new(0, 0.15, 0)

local FOV_CIRCLE = nil

local function createFOVCircle()
    if FOV_CIRCLE then FOV_CIRCLE:Remove() end
    FOV_CIRCLE = Drawing.new("Circle")
    FOV_CIRCLE.Thickness = 2
    FOV_CIRCLE.Color = Color3.fromRGB(255, 0, 0)
    FOV_CIRCLE.Transparency = 0.75
    FOV_CIRCLE.Filled = false
    FOV_CIRCLE.NumSides = 64
    FOV_CIRCLE.Radius = fovRadius
    FOV_CIRCLE.Visible = showFOV
end

local function isAlive(plr)
    if not plr or not plr.Character then return false end
    local humanoid = plr.Character:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

local function isVisible(target)
    if not target or not target.Character or not target.Character:FindFirstChild("Head") then return false end
    local head = target.Character.Head
    local origin = Camera.CFrame.Position
    local direction = (head.Position - origin)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {player.Character or Instance.new("Folder")}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true
    
    local result = workspace:Raycast(origin, direction, raycastParams)
    return result and result.Instance and result.Instance:IsDescendantOf(target.Character)
end

local function getClosestPlayerInFOV()
    local closest = nil
    local shortestDistance = math.huge
    local center = Camera.ViewportSize / 2

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and isAlive(plr) and plr.Character:FindFirstChild("Head") then
            local head = plr.Character.Head
            local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
            if onScreen then
                local distanceFromCenter = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                if distanceFromCenter <= fovRadius and isVisible(plr) then
                    if distanceFromCenter < shortestDistance then
                        shortestDistance = distanceFromCenter
                        closest = plr
                    end
                end
            end
        end
    end
    return closest
end

-- Loop principal
RunService.RenderStepped:Connect(function()
    if FOV_CIRCLE then
        FOV_CIRCLE.Visible = showFOV
        FOV_CIRCLE.Position = Camera.ViewportSize / 2
        FOV_CIRCLE.Radius = fovRadius
    end

    if not aimbotEnabled then return end

    local target = getClosestPlayerInFOV()
    if target and target.Character and target.Character:FindFirstChild("Head") then
        local headPos = target.Character.Head.Position + headOffset
        local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, headPos)
        Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, smoothness)
    end
end)

----- ESP -----
local espEnabled = false
local boxes = {}
local tracers = {}

local function createESP(plr)
    if plr == player then return end
    local box = Drawing.new("Square")
    box.Visible = false
    box.Color = Color3.fromRGB(255, 0, 0)
    box.Thickness = 2
    box.Transparency = 1
    box.Filled = false
    
    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = Color3.fromRGB(255, 0, 0)
    tracer.Thickness = 1.8
    tracer.Transparency = 1

    boxes[plr] = box
    tracers[plr] = tracer
end

for _, plr in pairs(Players:GetPlayers()) do createESP(plr) end
Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(function(plr)
    if boxes[plr] then boxes[plr]:Remove() boxes[plr] = nil end
    if tracers[plr] then tracers[plr]:Remove() tracers[plr] = nil end
end)

RunService.RenderStepped:Connect(function()
    if not espEnabled then
        for _, v in pairs(boxes) do v.Visible = false end
        for _, v in pairs(tracers) do v.Visible = false end
        return
    end

    local topCenter = Vector2.new(Camera.ViewportSize.X / 2, 30)
    for plr, box in pairs(boxes) do
        local tracer = tracers[plr]
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Head") and isAlive(plr) then
            local rootPart = plr.Character.HumanoidRootPart
            local head = plr.Character.Head
            local vector, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
            
            if onScreen then
                local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                local legPos = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))
                local height = (headPos.Y - legPos.Y)
                local width = height / 2
                
                box.Size = Vector2.new(width, height)
                box.Position = Vector2.new(vector.X - width/2, vector.Y - height/2 + 2)
                box.Visible = true

                if tracer then
                    tracer.From = topCenter
                    tracer.To = Vector2.new(vector.X, vector.Y)
                    tracer.Visible = true
                end
            else
                box.Visible = false
                if tracer then tracer.Visible = false end
            end
        else
            box.Visible = false
            if tracer then tracer.Visible = false end
        end
    end
end)

